Remove Boost targets

The warehouse_ros package uses boost:shared_ptr. Since boost::shared_ptr
is part of the header-only Boost.SmartPtr library, you do not need to
link any compiled Boost libraries.

The header files are already located in the default include directory.
We choose not to add ${Boost_INCLUDE_DIRS} to target_include_directories
to avoid introducing a buildpath QA problem.

Upstream-Status: Pending

Signed-off: Rob Woolley <rob.woolley@windriver.com>

diff --git a/CMakeLists.txt b/CMakeLists.txt
index d1a1306..9721091 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -36,18 +36,14 @@ add_library(warehouse_ros SHARED
 )
 target_link_libraries(warehouse_ros PUBLIC OpenSSL::Crypto)
 set_target_properties(warehouse_ros PROPERTIES WINDOWS_EXPORT_ALL_SYMBOLS TRUE)
-ament_target_dependencies(warehouse_ros PUBLIC ${THIS_PACKAGE_INCLUDE_DEPENDS}
-  Boost
-)
+ament_target_dependencies(warehouse_ros PUBLIC ${THIS_PACKAGE_INCLUDE_DEPENDS})
 target_include_directories(warehouse_ros
   PUBLIC $<BUILD_INTERFACE:${CMAKE_CURRENT_SOURCE_DIR}/include>
   PUBLIC $<INSTALL_INTERFACE:include>
 )

 add_executable(warehouse_test_dbloader src/test_dbloader.cpp)
-ament_target_dependencies(warehouse_test_dbloader PUBLIC ${THIS_PACKAGE_INCLUDE_DEPENDS}
-  Boost
-)
+ament_target_dependencies(warehouse_test_dbloader PUBLIC ${THIS_PACKAGE_INCLUDE_DEPENDS})
 target_link_libraries(warehouse_test_dbloader PUBLIC warehouse_ros)

 install(
