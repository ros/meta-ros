 {
-  string out = in;
+  std::string out = in;
 
   if ((!in.empty()) && (in[0] == '/')) {
     out.erase(0, 1);
@@ -31,13 +29,13 @@ std::string strip_leading_slash(const st
   return out;
 }
 
-Tokens split(const string & tokenstring, char delimiter)
+Tokens split(const std::string & tokenstring, char delimiter)
 {
   Tokens tokens;
 
   size_t current_pos = 0;
   size_t pos = 0;
