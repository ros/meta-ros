Signed-off-by: Rob Woolley <rob.woolley@windriver.com>

From cfe97b176a22fbc5d803f2b0e14a0f7c2d6a33a5 Mon Sep 17 00:00:00 2001
From: Emerson Knapp <537409+emersonknapp@users.noreply.github.com>
Date: Fri, 20 Mar 2026 09:44:11 -0700
Subject: [PATCH] Create an aggregate target for rosidl generated interfaces
 targets (#947)

Signed-off-by: Emerson Knapp <emerson.b.knapp@gmail.com>
(cherry picked from commit e61e46df2d4111606eb5a1eb969bae23f97a8e01)
---
 ...idl_cmake_aggregate_target-extras.cmake.in | 10 +++++++
 ..._cmake_aggregate_target_package_hook.cmake | 26 +++++++++++++++++++
 rosidl_cmake/rosidl_cmake-extras.cmake        | 13 ++++++++++
 3 files changed, 49 insertions(+)
 create mode 100644 rosidl_cmake/cmake/rosidl_cmake_aggregate_target-extras.cmake.in
 create mode 100644 rosidl_cmake/cmake/rosidl_cmake_aggregate_target_package_hook.cmake

diff --git rosidl_cmake/cmake/rosidl_cmake_aggregate_target-extras.cmake.in rosidl_cmake/cmake/rosidl_cmake_aggregate_target-extras.cmake.in
new file mode 100644
index 000000000..379947165
--- /dev/null
+++ rosidl_cmake/cmake/rosidl_cmake_aggregate_target-extras.cmake.in
@@ -0,0 +1,10 @@
+# generated from rosidl_cmake/cmake/rosidl_cmake_aggregate_target-extras.cmake.in
+
+# Create a convenience aggregate target @PROJECT_NAME@::@PROJECT_NAME@
+# that links all generated interface targets, so downstream packages can use
+# a single modern CMake target name instead of ${@PROJECT_NAME@_TARGETS}.
+if(@PROJECT_NAME@_TARGETS AND NOT TARGET @PROJECT_NAME@::@PROJECT_NAME@)
+  add_library(@PROJECT_NAME@::@PROJECT_NAME@ INTERFACE IMPORTED)
+  set_target_properties(@PROJECT_NAME@::@PROJECT_NAME@ PROPERTIES
+    INTERFACE_LINK_LIBRARIES "${@PROJECT_NAME@_TARGETS}")
+endif()
diff --git rosidl_cmake/cmake/rosidl_cmake_aggregate_target_package_hook.cmake rosidl_cmake/cmake/rosidl_cmake_aggregate_target_package_hook.cmake
new file mode 100644
index 000000000..f2ef9eb31
--- /dev/null
+++ rosidl_cmake/cmake/rosidl_cmake_aggregate_target_package_hook.cmake
@@ -0,0 +1,26 @@
