Subject: [PATCH 09/15] Modernize cmake (#50)

- Increase minimum cmake version
- Drop enforcement of C++14 standard (C++17 is default)
---
 CMakeLists.txt | 7 +------
 1 file changed, 1 insertion(+), 6 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index e0d6fc6..99a8807 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -1,11 +1,6 @@
-cmake_minimum_required(VERSION 3.5)
+cmake_minimum_required(VERSION 3.20)
 project(random_numbers)
 
-# Default to C++14
-if(NOT CMAKE_CXX_STANDARD)
-  set(CMAKE_CXX_STANDARD 14)
-endif()
-
 find_package(ament_cmake REQUIRED)
 find_package(Boost REQUIRED date_time random thread)
 
