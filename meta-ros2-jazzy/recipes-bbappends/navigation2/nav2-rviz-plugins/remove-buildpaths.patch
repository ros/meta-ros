Remove buildpaths

The include directories end up in nav2_rviz_pluginsExport.cmake which causes
a buildpaths QA failure.

Remove them as they are not required for build. The headers should be
automatically provided through targets provided with target_link_libraries.

Upstream-Status: Pending
Signed-off-by: Rob Woolley <rob.woolley@windriver.com>

Index: nav2-rviz-plugins-1.3.11-1/CMakeLists.txt
===================================================================
--- nav2-rviz-plugins-1.3.11-1.orig/CMakeLists.txt
+++ nav2-rviz-plugins-1.3.11-1/CMakeLists.txt
@@ -95,14 +95,15 @@ ament_target_dependencies(${library_name
 )
 
 target_include_directories(${library_name} PUBLIC
-  ${Qt5Widgets_INCLUDE_DIRS}
-  ${OGRE_INCLUDE_DIRS}
-  ${nav2_route_INCLUDE_DIRS}
+  "$<BUILD_INTERFACE:${CMAKE_CURRENT_SOURCE_DIR}/include>"
+  "$<INSTALL_INTERFACE:include/${PROJECT_NAME}>"
 )
 
 target_link_libraries(${library_name}
   rviz_common::rviz_common
   nav2_route::route_server_core
+  nav2_route::graph_file_loaders
+  nav2_route::graph_file_savers
 )
 
 # Causes the visibility macros to use dllexport rather than dllimport,
