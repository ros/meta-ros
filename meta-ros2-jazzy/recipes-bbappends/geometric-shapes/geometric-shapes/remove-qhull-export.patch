This fixes a buildpaths QA error by removing the QHULL export.

Upstream-Status: Backport [https://github.com/moveit/geometric_shapes/commit/59671b8d07a4d391b39baebdd837b10fb5417e94]
Signed-off-by: Rob Woolley <rob.woolley@windriver.com>

From 59671b8d07a4d391b39baebdd837b10fb5417e94 Mon Sep 17 00:00:00 2001
From: Robert Haschke <rhaschke@techfak.uni-bielefeld.de>
Date: Fri, 6 Jun 2025 14:46:40 +0200
Subject: [PATCH] Fix compiler warnings

- declare qhull includes as SYSTEM
- fix uninitialized Vector3d usage
---
 CMakeLists.txt | 2 +-
 src/bodies.cpp | 2 +-
 2 files changed, 2 insertions(+), 2 deletions(-)

Index: geometric-shapes-2.3.2-1/CMakeLists.txt
===================================================================
--- geometric-shapes-2.3.2-1.orig/CMakeLists.txt
+++ geometric-shapes-2.3.2-1/CMakeLists.txt
@@ -105,7 +105,7 @@ target_link_libraries(${PROJECT_NAME}
     rclcpp::rclcpp
     resource_retriever::resource_retriever
 )
-target_include_directories(${PROJECT_NAME} PRIVATE ${QHULL_INCLUDE_DIRS})
+target_include_directories(${PROJECT_NAME} SYSTEM PRIVATE ${QHULL_INCLUDE_DIRS})
 
 if(BUILD_TESTING)
   # Unit tests
Index: geometric-shapes-2.3.2-1/src/bodies.cpp
===================================================================
--- geometric-shapes-2.3.2-1.orig/src/bodies.cpp
+++ geometric-shapes-2.3.2-1/src/bodies.cpp
@@ -868,7 +868,7 @@ void bodies::ConvexMesh::useDimensions(c
   mesh_data_->triangles_.clear();
   mesh_data_->vertices_.clear();
   mesh_data_->mesh_radiusB_ = 0.0;
-  mesh_data_->mesh_center_ = Eigen::Vector3d();
+  mesh_data_->mesh_center_ = Eigen::Vector3d::Zero();
 
   double xdim = maxX - minX;
   double ydim = maxY - minY;
