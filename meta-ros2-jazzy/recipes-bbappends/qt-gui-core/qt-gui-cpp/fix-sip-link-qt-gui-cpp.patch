From: Chris Kohn <chris.kohn@amd.com>
Subject: [PATCH] qt_gui_cpp_sip: Fix linker ordering for SIP bindings

The SIP Python bindings need to link against libqt_gui_cpp.so to
resolve symbols at runtime. With --as-needed, the library was placed
in LFLAGS (before object files) via the qt_gui_cpp_LIBRARIES CMake
target path and got dropped by the linker since no symbols were yet
undefined. This results in an ImportError when importing
libqt_gui_cpp_sip on the target.

Fix by adding qt_gui_cpp as a library name (not a CMake target path)
so it ends up in LIBS (after object files) where --as-needed keeps
it. Also add CMAKE_BINARY_DIR to library search dirs so the linker
can find libqt_gui_cpp.so during the build.

AI-Generated: Claude claude-opus-4-6
Signed-off-by: Chris Kohn <chris.kohn@amd.com>

diff --git a/src/qt_gui_cpp_sip/CMakeLists.txt b/src/qt_gui_cpp_sip/CMakeLists.txt
--- a/src/qt_gui_cpp_sip/CMakeLists.txt
+++ b/src/qt_gui_cpp_sip/CMakeLists.txt
@@ -28,7 +28,8 @@
 
 # maintain context for different named target
 set(qt_gui_cpp_sip_INCLUDE_DIRS ${qt_gui_cpp_INCLUDE_DIRS} "${CMAKE_CURRENT_SOURCE_DIR}/../../include")
-set(qt_gui_cpp_sip_LIBRARY_DIRS ${qt_gui_cpp_LIBRARY_DIRS} lib)
+# Add CMAKE_BINARY_DIR so the linker can find libqt_gui_cpp.so
+set(qt_gui_cpp_sip_LIBRARY_DIRS ${qt_gui_cpp_LIBRARY_DIRS} lib ${CMAKE_BINARY_DIR})
 set(qt_gui_cpp_sip_LDFLAGS_OTHER ${qt_gui_cpp_LDFLAGS_OTHER})
 
 ament_get_recursive_properties(deps_include_dirs deps_libraries ${pluginlib_TARGETS})
@@ -56,7 +57,6 @@
 set(_qt_gui_cpp_sip_LIBRARIES
   ${deps_libraries}
   ${Python3_LIBRARIES}
-  ${qt_gui_cpp_LIBRARIES}
 )
 
 # sip needs libraries to have resolved paths and cannot link to cmake targets
@@ -70,6 +70,10 @@
   endif()
 endforeach()
 
+# Add qt_gui_cpp as a library name (not path) so it goes into LIBS not LFLAGS
+# This ensures proper linking with --as-needed since LIBS comes after objects
+list(APPEND qt_gui_cpp_sip_LIBRARIES qt_gui_cpp)
+
 find_package(python_qt_binding REQUIRED)
 include(${python_qt_binding_DIR}/sip_helper.cmake)
 
