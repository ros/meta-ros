-		FIND_PACKAGE(NumPy)
+	if(BUILD_PYBULLET_NUMPY)
+	        find_package(Python3 ${PYTHON_VERSION_PYBULLET} COMPONENTS Interpreter Development NumPy REQUIRED)
 		if (PYTHON_NUMPY_FOUND)
 			message("NumPy found")
 			add_definitions(-DPYBULLET_USE_NUMPY)
 		else()
 			message("NumPy not found")
 		endif()
-	ENDIF()
+	else()
+	        find_package(Python3 ${PYTHON_VERSION_PYBULLET} COMPONENTS Interpreter Development REQUIRED)
+	endif()
 
 	IF(WIN32)
 		SET(BUILD_SHARED_LIBS OFF CACHE BOOL "Shared Libs" FORCE)
